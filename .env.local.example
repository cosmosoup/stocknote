# Claude (Anthropic) API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# Gmail SMTP（メール送信）
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
NOTIFY_EMAIL=your@email.com

# Vercel Cron Job 保護用シークレット（必須・任意の長いランダム文字列を設定）
CRON_SECRET=your-random-secret-string-here

# ログイン認証
AUTH_PASSWORD=your-login-password
# AUTH_SECRET は openssl rand -hex 32 などで生成した64文字の16進数文字列
AUTH_SECRET=your-64-char-hex-string

# Google Sheets 連携（任意 — 未設定の場合はSheets追記をスキップ）
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEETS_ID=
